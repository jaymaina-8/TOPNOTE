# Copy to the project root and adjust values locally. Never commit real secrets.

# Supabase (public — safe to expose in the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: privileged Postgres access for internal dashboard reads/writes (service role).
# Never expose this or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Supabase Storage bucket for dashboard product image uploads (default: product-images).
# Create this bucket in Supabase Dashboard → Storage; use a public bucket if you store public URLs in products.image_url.
# SUPABASE_STORAGE_PRODUCT_IMAGES_BUCKET=product-images

# Comma-separated emails allowed to use /dashboard/* after Supabase Auth sign-in (trimmed, case-insensitive).
# If unset or empty, dashboard access is denied for everyone (fail closed).
DASHBOARD_ALLOWED_EMAILS=admin@topnote.com
